{
  "name": "debdi-pos-windows",
  "version": "1.0.0",
  "private": true,
  "description": "Debdi POS — Windows native wrapper (Electron)",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win --x64",
    "dist:nsis": "electron-builder --win nsis --x64",
    "dist:portable": "electron-builder --win portable --x64"
  },
  "build": {
    "appId": "uz.debdi.pos",
    "productName": "Debdi POS",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "icon.ico",
      "package.json"
    ],
    "win": {
      "target": ["nsis", "portable"],
      "icon": "icon.ico",
      "publisherName": "Debdi",
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Debdi POS"
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "electron-updater": "^6.3.9",
    "@serialport/parser-readline": "^12.0.0",
    "serialport": "^12.0.0",
    "node-thermal-printer": "^4.4.4",
    "usb": "^2.13.0"
  }
}
