// Delivery Management System Schema (PostgreSQL)
// Same models as default schema, but datasource provider is postgresql

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id                         String            @id @default(cuid())
  email                      String            @unique
  password                   String?
  name                       String
  role                       AdminRole         @default(SUPER_ADMIN)
  isActive                   Boolean           @default(true)
  createdBy                  String?
  createdAt                  DateTime          @default(now())
  updatedAt                  DateTime          @updatedAt
  trialEndsAt                DateTime?
  allowedTabs                String?
  googleId                   String?           @unique
  hasPassword                Boolean           @default(true)
  phone                      String?
  latitude                   Float?
  longitude                  Float?
  transportType              String?
  vehicleNumber              String?
  maxLoad                    Int               @default(0)
  isOnShift                  Boolean           @default(false)
  shiftStartedAt             DateTime?
  shiftEndedAt               DateTime?
  lastSeenAt                 DateTime?
  averageDeliveryMinutes     Float?
  createdAdmins              Admin[]           @relation("AdminHierarchy")
  creator                    Admin?            @relation("AdminHierarchy", fields: [createdBy], references: [id])
  orders                     Order[]           @relation("OrderAdmin")
  courierOrders              Order[]           @relation("OrderCourier")
  clients                    Customer[]        @relation("ClientDefaultCourier")
  createdClients             Customer[]        @relation("ClientCreator")
  actionLogs                 ActionLog[]
  interfaceConfig            InterfaceConfig?
  features                   Feature[]         @relation("AdminFeatures")
  accounts                   Account[]
  sentMessages               Message[]         @relation("MessageSender")
  conversationsAsP1          Conversation[]    @relation("ConversationParticipant1")
  conversationsAsP2          Conversation[]    @relation("ConversationParticipant2")
  website                    Website?
  companyBalance             Float             @default(0)
  salary                     Int               @default(0)
  transactions               Transaction[]
  salaryReceivedTransactions Transaction[]     @relation("SalaryRecipient")
  menuSets                   MenuSet[]
  orderAuditEvents           OrderAuditEvent[]

  @@map("admins")
}

enum AdminRole {
  SUPER_ADMIN
  MIDDLE_ADMIN
  LOW_ADMIN
  COURIER
  WORKER
}

enum PlanType {
  CLASSIC
  INDIVIDUAL
  DIABETIC
}

enum FeatureType {
  TEXT
  SELECT
}

model Customer {
  id                String        @id @default(cuid())
  name              String
  nickName          String? // Short name or alias
  phone             String // Removed @unique, will use composite key below
  address           String
  preferences       String?
  orderPattern      String?
  password          String? // Hashed password for authentication
  isActive          Boolean       @default(true)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  latitude          Float?
  longitude         Float?
  deletedAt         DateTime?
  deletedBy         String?
  createdBy         String?
  defaultCourierId  String?
  defaultCourier    Admin?        @relation("ClientDefaultCourier", fields: [defaultCourierId], references: [id])
  creator           Admin?        @relation("ClientCreator", fields: [createdBy], references: [id])
  calories          Int           @default(2000)
  planType          PlanType      @default(CLASSIC)
  dailyPrice        Int           @default(84000) // Price in sum
  notes             String? // Individual requirements, excluded products, etc.
  deliveryDays      String?
  autoOrdersEnabled Boolean       @default(true)
  balance           Float         @default(0)
  transactions      Transaction[]

  orders Order[]

  assignedSetId String?
  assignedSet   MenuSet? @relation("ClientAssignedSet", fields: [assignedSetId], references: [id])

  // POS extensions
  loyaltyMember LoyaltyMember?
  email         String?
  birthday      DateTime?
  totalSpent    Float          @default(0)
  totalOrders   Int            @default(0)
  lastOrderAt   DateTime?
  tags          String? // comma-separated tags

  // Phone is unique per admin, but allow re-creation after deletion (deletedAt is null for active)
  @@unique([phone, createdBy, deletedAt])
  @@map("customers")
}

model Order {
  id               String        @id @default(cuid())
  orderNumber      Int           @unique
  orderStatus      OrderStatus   @default(NEW) @map("status")
  customerId       String
  customer         Customer      @relation(fields: [customerId], references: [id])
  deliveryDate     DateTime?     @default(now())
  deliveryAddress  String
  deliveryTime     String?
  latitude         Float?
  longitude        Float?
  quantity         Int           @default(1)
  calories         Int           @default(1600)
  specialFeatures  String?
  notes            String?
  paymentStatus    PaymentStatus @default(UNPAID)
  paymentMethod    PaymentMethod @default(CASH)
  isPrepaid        Boolean       @default(false)
  priority         Int           @default(3)
  sourceChannel    String?       @default("ADMIN_PANEL")
  statusChangedAt  DateTime      @default(now())
  assignedAt       DateTime?
  pickedUpAt       DateTime?
  pausedAt         DateTime?
  resumedAt        DateTime?
  deliveredAt      DateTime?
  failedAt         DateTime?
  canceledAt       DateTime?
  confirmedAt      DateTime?
  etaMinutes       Int?
  routeDistanceKm  Float?
  routeDurationMin Int?
  sequenceInRoute  Int?
  customerRating   Int?
  customerFeedback String?
  amountReceived   Float?
  lastLatitude     Float?
  lastLongitude    Float?
  lastLocationAt   DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  orderType        OrderType     @default(MORNING)
  fromAutoOrder    Boolean       @default(false)
  deletedAt        DateTime?

  adminId String?
  admin   Admin?  @relation("OrderAdmin", fields: [adminId], references: [id])

  courierId String?
  courier   Admin?            @relation("OrderCourier", fields: [courierId], references: [id])
  events    OrderAuditEvent[]

  // POS extensions
  items         OrderItem[]
  payments      Payment[]
  receipts      Receipt[]
  subtotal      Float       @default(0)
  taxTotal      Float       @default(0)
  discountTotal Float       @default(0)
  tipTotal      Float       @default(0)
  grandTotal    Float       @default(0)
  tableId       String?
  guestCount    Int?
  serviceMode   String? // DINE_IN | TAKEAWAY | DELIVERY | DRIVE_THRU

  @@map("orders")
}

enum OrderStatus {
  NEW
  PENDING
  IN_PROCESS
  IN_DELIVERY
  PAUSED
  DELIVERED
  CANCELED
  FAILED

  @@map("order_status_new")
}

enum PaymentStatus {
  PAID
  UNPAID
  PARTIAL
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
}

enum OrderType {
  MORNING
  EVENING
}

enum OrderEventType {
  CREATED
  STATUS_CHANGED
  DETAILS_UPDATED
  COURIER_ASSIGNED
  COURIER_UNASSIGNED
  DELIVERY_STARTED
  DELIVERY_PAUSED
  DELIVERY_RESUMED
  DELIVERY_COMPLETED
  PAYMENT_UPDATED
  REORDERED
}

model OrderAuditEvent {
  id             String         @id @default(cuid())
  orderId        String
  order          Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  eventType      OrderEventType
  actorAdminId   String?
  actorAdmin     Admin?         @relation(fields: [actorAdminId], references: [id], onDelete: SetNull)
  actorRole      String?
  actorName      String?
  previousStatus OrderStatus?
  nextStatus     OrderStatus?
  payload        Json?
  message        String?
  occurredAt     DateTime       @default(now())

  @@index([orderId, occurredAt])
  @@map("order_audit_events")
}

model ActionLog {
  id          String   @id @default(cuid())
  adminId     String
  action      String
  entityType  String?
  entityId    String?
  oldValues   String?
  newValues   String?
  description String?
  details     String?
  createdAt   DateTime @default(now())

  admin Admin @relation(fields: [adminId], references: [id])

  @@index([adminId])
  @@map("action_logs")
}

model InterfaceConfig {
  id       String @id @default(cuid())
  adminId  String @unique
  theme    String @default("light")
  language String @default("ru")

  admin Admin @relation(fields: [adminId], references: [id])

  @@map("interface_configs")
}

model Feature {
  id           String      @id @default(cuid())
  ownerAdminId String
  name         String
  description  String
  type         FeatureType
  options      Json?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  ownerAdmin Admin @relation("AdminFeatures", fields: [ownerAdminId], references: [id], onDelete: Cascade)

  @@index([ownerAdminId])
  @@map("features")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user Admin @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Conversation {
  id             String   @id @default(cuid())
  participant1Id String
  participant2Id String
  lastMessage    String?
  lastMessageAt  DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  participant1 Admin     @relation("ConversationParticipant1", fields: [participant1Id], references: [id], onDelete: Cascade)
  participant2 Admin     @relation("ConversationParticipant2", fields: [participant2Id], references: [id], onDelete: Cascade)
  messages     Message[]

  @@unique([participant1Id, participant2Id])
  @@index([participant1Id])
  @@index([participant2Id])
  @@map("conversations")
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())

  sender       Admin        @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
  @@map("messages")
}

model Website {
  id          String   @id @default(cuid())
  adminId     String   @unique // One site per middle admin
  subdomain   String   @unique // e.g. "healthy-food"
  theme       String // JSON: colors, fonts
  content     String // JSON: multilingual text for landing page
  chatEnabled Boolean  @default(false) // Enable client-to-client chat
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  admin Admin @relation(fields: [adminId], references: [id])

  @@map("websites")
}

model WarehouseItem {
  id           String   @id @default(cuid())
  name         String   @unique
  amount       Float    @default(0)
  unit         String   @default("gr")
  // kcal per 1 gram (used for set/day calorie totals).
  kcalPerGram  Float?   @default(0)
  // Last known purchase price for this item (used for audit + inventory economics).
  // `pricePerUnit` is in UZS per `priceUnit` (typically "kg").
  pricePerUnit Float?
  priceUnit    String   @default("kg")
  updatedAt    DateTime @updatedAt

  @@map("warehouse_items")
}

model DailyCookingPlan {
  id          String   @id @default(cuid())
  date        DateTime @unique
  menuNumber  Int
  dishes      Json // Stores quantities: { [dishId: number]: number }
  cookedStats Json? // Stores cooked quantities: { [dishId: string]: { "1200": 5, "1600": 3 } }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("daily_cooking_plans")
}

model Menu {
  id        String   @id @default(cuid())
  number    Int      @unique // 1-21
  dishes    Dish[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("menus")
}

model Transaction {
  id          String          @id @default(cuid())
  amount      Float
  type        TransactionType
  description String?
  category    String? // e.g. "MANUAL_ADJUSTMENT", "ORDER_PAYMENT", "COMPANY_FUNDS"
  createdAt   DateTime        @default(now())

  adminId String?
  admin   Admin?  @relation(fields: [adminId], references: [id])

  // For SALARY expense transactions: who receives the salary.
  salaryRecipientAdminId String?
  salaryRecipient        Admin?  @relation("SalaryRecipient", fields: [salaryRecipientAdminId], references: [id])

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  @@index([adminId])
  @@index([salaryRecipientAdminId])
  @@index([customerId])
  @@map("transactions")
}

enum TransactionType {
  INCOME
  EXPENSE
}

model Dish {
  id              String   @id @default(cuid())
  name            String
  description     String?
  mealType        String
  ingredients     Json // [{ name: string, amount: number, unit: string }]
  calorieMappings Json? // { "7": ["1200", "2000"], "8": ["1600"] }
  menus           Menu[] // Relation to Menu
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("dishes")
}

model MenuSet {
  id            String   @id @default(cuid())
  name          String
  description   String?
  menuNumber    Int      @default(0)
  calorieGroups Json // Custom calorie/dish config
  isActive      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  adminId         String?
  admin           Admin?     @relation(fields: [adminId], references: [id])
  assignedClients Customer[] @relation("ClientAssignedSet")

  @@index([adminId])
  @@map("menu_sets")
}

// ═══════════════════════════════════════════════════════════════════════════
// POS EXTENSIONS — Products, Inventory, Tables, Payments, Loyalty, Shifts
// Added to upgrade Debdi from a delivery-only platform into a full-featured
// POS SaaS comparable to Square / Loyverse / Toast / Lightspeed.
// ═══════════════════════════════════════════════════════════════════════════

// Product catalog (separate from prepared meal `Dish`).
// Used by retail/POS flows: SKUs, barcodes, variants, modifiers, categories.
model Product {
  id           String            @id @default(cuid())
  ownerAdminId String
  sku          String?
  barcode      String? // EAN-13 / UPC / QR
  name         String
  description  String?
  categoryId   String?
  category     ProductCategory?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  imageUrl     String?
  costPrice    Float? // What we paid (UZS)
  sellPrice    Float             @default(0) // Default sell price (UZS)
  taxRate      Float             @default(0) // 0..1 fraction (0.12 = 12% VAT)
  trackStock   Boolean           @default(true)
  stockOnHand  Float             @default(0)
  reorderLevel Float? // Low-stock threshold
  unit         String            @default("pcs") // pcs / kg / l / m
  isActive     Boolean           @default(true)
  isFavorite   Boolean           @default(false) // Pin to POS quick grid
  color        String? // Tile color in POS grid
  kitchenStation String? // KDS routing: 'HOT', 'COLD', 'BAR', 'GRILL', 'BAKERY' or custom
  variants     ProductVariant[]
  modifiers    ProductModifier[] @relation("ProductModifiersList")
  orderItems   OrderItem[]
  stockMoves   StockMovement[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@unique([ownerAdminId, sku])
  @@unique([ownerAdminId, barcode])
  @@index([ownerAdminId])
  @@index([categoryId])
  @@map("products")
}

model ProductCategory {
  id           String            @id @default(cuid())
  ownerAdminId String
  name         String
  color        String? // Hex color for POS grid
  icon         String? // Lucide icon name
  parentId     String?
  parent       ProductCategory?  @relation("CategoryChildren", fields: [parentId], references: [id], onDelete: SetNull)
  children     ProductCategory[] @relation("CategoryChildren")
  products     Product[]
  sortOrder    Int               @default(0)
  isActive     Boolean           @default(true)
  kitchenStation String? // Default station for products in this category (HOT/COLD/BAR/GRILL/BAKERY)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([ownerAdminId])
  @@map("product_categories")
}

model ProductVariant {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name        String // "Small / Medium / Large" or "Red / Blue"
  sku         String?
  barcode     String?
  priceDelta  Float    @default(0) // Added to base sellPrice
  stockOnHand Float    @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([productId])
  @@map("product_variants")
}

model ProductModifier {
  id           String    @id @default(cuid())
  ownerAdminId String
  name         String // "Add cheese", "Extra shot", "No sugar"
  priceDelta   Float     @default(0)
  groupName    String? // "Toppings", "Size", "Sauce"
  isRequired   Boolean   @default(false)
  maxSelect    Int       @default(1)
  products     Product[] @relation("ProductModifiersList")
  createdAt    DateTime  @default(now())

  @@index([ownerAdminId])
  @@map("product_modifiers")
}

// Order line items (replaces the per-order single-item assumption).
model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  variantId String?
  name      String // Snapshot of product name at sale time
  sku       String?
  quantity  Float    @default(1)
  unitPrice Float
  discount  Float    @default(0) // Per-line discount (UZS)
  taxRate   Float    @default(0)
  total     Float // (unitPrice * quantity) - discount + tax
  modifiers Json? // Snapshot of selected modifiers
  notes     String?
  // Course pacing & KDS fire timer (inspired by Toast / Lightspeed Mar-2026):
  courseNumber Int?    // 1=appetizer, 2=main, 3=dessert, etc. NULL = not coursed.
  firedAt   DateTime? // Set when KDS picks the item up. Powers the
                      // 'time since fired' badge that turns amber/red on
                      // delays. NULL = not fired yet.
  readyAt   DateTime? // Set when item is bumped to 'ready' on KDS.
  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

// Stock movements — every change to inventory is logged here for auditability.
model StockMovement {
  id          String            @id @default(cuid())
  productId   String
  product     Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  type        StockMovementType
  quantity    Float // Signed: positive = in, negative = out
  reason      String? // "Sale", "Purchase", "Waste", "Manual adjust"
  reference   String? // OrderId, PurchaseOrderId, etc.
  costPrice   Float?
  performedBy String? // Admin id
  createdAt   DateTime          @default(now())

  @@index([productId])
  @@index([createdAt])
  @@map("stock_movements")
}

enum StockMovementType {
  SALE
  PURCHASE
  RETURN
  ADJUSTMENT
  WASTE
  TRANSFER_IN
  TRANSFER_OUT
  PRODUCTION
}

// Restaurant table layout — supports floor plans, sections, statuses.
model RestaurantTable {
  id             String        @id @default(cuid())
  ownerAdminId   String
  name           String // "T1", "Bar-3", "Patio-A"
  sectionId      String?
  section        TableSection? @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  capacity       Int           @default(4)
  shape          String        @default("rect") // rect | circle | square
  positionX      Float         @default(0)
  positionY      Float         @default(0)
  width          Float         @default(80)
  height         Float         @default(80)
  status         TableStatus   @default(AVAILABLE)
  currentOrderId String?
  // QR-ordering: opaque random token printed on the table sticker.
  // The public URL /t/<qrToken> renders a guest-facing menu and lets the
  // diner add to cart from their phone without staff intervention.
  qrToken        String?       @unique
  qrEnabled      Boolean       @default(false)
  reservations   Reservation[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([ownerAdminId])
  @@index([sectionId])
  @@map("restaurant_tables")
}

model TableSection {
  id           String            @id @default(cuid())
  ownerAdminId String
  name         String // "Main hall", "Patio", "VIP"
  color        String?
  tables       RestaurantTable[]
  sortOrder    Int               @default(0)
  createdAt    DateTime          @default(now())

  @@index([ownerAdminId])
  @@map("table_sections")
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  CLEANING
  BLOCKED
}

// Reservations / bookings.
model Reservation {
  id            String            @id @default(cuid())
  ownerAdminId  String
  tableId       String?
  table         RestaurantTable?  @relation(fields: [tableId], references: [id], onDelete: SetNull)
  customerName  String
  customerPhone String?
  partySize     Int               @default(2)
  startsAt      DateTime
  durationMin   Int               @default(90)
  status        ReservationStatus @default(BOOKED)
  notes         String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([ownerAdminId, startsAt])
  @@map("reservations")
}

enum ReservationStatus {
  BOOKED
  CONFIRMED
  ARRIVED
  SEATED
  COMPLETED
  CANCELED
  NO_SHOW
}

// Cashier shift / register session.
model CashierShift {
  id              String               @id @default(cuid())
  cashierId       String // Admin (LOW_ADMIN / WORKER) id
  registerId      String? // Optional: a physical register identifier
  openedAt        DateTime             @default(now())
  closedAt        DateTime?
  openingFloat    Float                @default(0) // Cash in drawer at start
  closingCash     Float?
  expectedCash    Float?
  cashDelta       Float? // Closing - expected
  totalSales      Float                @default(0)
  totalTax        Float                @default(0)
  totalDiscount   Float                @default(0)
  totalTips       Float                @default(0)
  ordersCount     Int                  @default(0)
  status          ShiftStatus          @default(OPEN)
  notes           String?
  payments        Payment[]
  drawerMovements CashDrawerMovement[]

  @@index([cashierId, openedAt])
  @@map("cashier_shifts")
}

enum ShiftStatus {
  OPEN
  CLOSED
  RECONCILED
}

// Payment records — multiple payments per order (split bill / partial pay).
model Payment {
  id             String           @id @default(cuid())
  orderId        String
  order          Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  shiftId        String?
  shift          CashierShift?    @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  method         PaymentMethod
  amount         Float
  tip            Float            @default(0)
  changeGiven    Float            @default(0)
  reference      String? // Card last4, terminal txn id, etc.
  refundedAmount Float            @default(0)
  status         PaymentTxnStatus @default(COMPLETED)
  processedAt    DateTime         @default(now())
  processedBy    String? // Admin id

  @@index([orderId])
  @@index([shiftId])
  @@map("payments")
}

enum PaymentTxnStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
  VOIDED
}

// Discounts & promotions.
model Discount {
  id           String       @id @default(cuid())
  ownerAdminId String
  name         String
  code         String? // Promo code (optional)
  type         DiscountType
  value        Float // % or absolute amount
  minSubtotal  Float?
  startsAt     DateTime?
  endsAt       DateTime?
  usageLimit   Int?
  usageCount   Int          @default(0)
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())

  @@unique([ownerAdminId, code])
  @@index([ownerAdminId])
  @@map("discounts")
}

enum DiscountType {
  PERCENT
  FIXED
  BOGO // Buy one get one
  BUNDLE
}

// Loyalty program — points, tiers, rewards.
model LoyaltyProgram {
  id                String          @id @default(cuid())
  ownerAdminId      String          @unique
  name              String          @default("Loyalty Program")
  pointsPerCurrency Float           @default(1) // 1 point per 1000 UZS spent
  currencyPerPoint  Float           @default(100) // 1 point = 100 UZS redemption
  isActive          Boolean         @default(true)
  tiers             LoyaltyTier[]
  members           LoyaltyMember[]
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@map("loyalty_programs")
}

model LoyaltyTier {
  id         String         @id @default(cuid())
  programId  String
  program    LoyaltyProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  name       String // "Bronze", "Silver", "Gold"
  minPoints  Int            @default(0)
  multiplier Float          @default(1.0) // Earn rate multiplier
  benefits   String?
  color      String?

  @@index([programId])
  @@map("loyalty_tiers")
}

model LoyaltyMember {
  id            String             @id @default(cuid())
  programId     String
  program       LoyaltyProgram     @relation(fields: [programId], references: [id], onDelete: Cascade)
  customerId    String             @unique
  customer      Customer           @relation(fields: [customerId], references: [id], onDelete: Cascade)
  points        Int                @default(0)
  lifetimeSpent Float              @default(0)
  tier          String? // Cached tier name
  joinedAt      DateTime           @default(now())
  pointsLogs    LoyaltyPointsLog[]

  @@index([programId])
  @@map("loyalty_members")
}

model LoyaltyPointsLog {
  id        String        @id @default(cuid())
  memberId  String
  member    LoyaltyMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  delta     Int // Signed (+earn / -redeem)
  reason    String // "Earned from order", "Redeemed", "Manual adjust"
  reference String? // OrderId
  createdAt DateTime      @default(now())

  @@index([memberId, createdAt])
  @@map("loyalty_points_logs")
}

// Suppliers and purchase orders.
model Supplier {
  id             String          @id @default(cuid())
  ownerAdminId   String
  name           String
  contactName    String?
  phone          String?
  email          String?
  address        String?
  notes          String?
  isActive       Boolean         @default(true)
  purchaseOrders PurchaseOrder[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([ownerAdminId])
  @@map("suppliers")
}

model PurchaseOrder {
  id           String              @id @default(cuid())
  ownerAdminId String
  supplierId   String
  supplier     Supplier            @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  reference    String? // Invoice number
  status       PurchaseOrderStatus @default(DRAFT)
  totalCost    Float               @default(0)
  receivedAt   DateTime?
  notes        String?
  items        PurchaseOrderItem[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([ownerAdminId])
  @@index([supplierId])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productId       String?
  warehouseItemId String?
  name            String
  quantity        Float
  unitCost        Float
  total           Float

  @@index([purchaseOrderId])
  @@map("purchase_order_items")
}

enum PurchaseOrderStatus {
  DRAFT
  ORDERED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELED
}

// Receipts (printed/digital) — separate from Order so we can re-print.
model Receipt {
  id            String      @id @default(cuid())
  orderId       String
  order         Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  receiptNumber String      @unique
  type          ReceiptType @default(SALE)
  format        String      @default("80mm") // 80mm | 58mm | A4 | EMAIL
  payload       Json // Snapshot of receipt data for re-print
  printedAt     DateTime?
  emailedTo     String?
  smsTo         String?
  createdAt     DateTime    @default(now())

  @@index([orderId])
  @@map("receipts")
}

enum ReceiptType {
  SALE
  REFUND
  KITCHEN
  BAR
  PROFORMA
  GIFT
}

// Notifications (in-app, push, email, sms).
model Notification {
  id          String           @id @default(cuid())
  recipientId String // Admin id
  type        NotificationType
  title       String
  body        String?
  link        String?
  data        Json?
  isRead      Boolean          @default(false)
  createdAt   DateTime         @default(now())

  @@index([recipientId, createdAt])
  @@map("notifications")
}

enum NotificationType {
  ORDER_CREATED
  ORDER_STATUS_CHANGED
  PAYMENT_RECEIVED
  LOW_STOCK
  SHIFT_OPENED
  SHIFT_CLOSED
  RESERVATION_REMINDER
  SYSTEM
}

// Multi-location support — branches/stores.
model Branch {
  id           String   @id @default(cuid())
  ownerAdminId String
  name         String
  code         String? // Short code: "DT01"
  address      String?
  phone        String?
  latitude     Float?
  longitude    Float?
  timezone     String   @default("Asia/Tashkent")
  currency     String   @default("UZS")
  taxRate      Float    @default(0.12)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([ownerAdminId])
  @@map("branches")
}

// Tax configuration.
model TaxRate {
  id           String   @id @default(cuid())
  ownerAdminId String
  name         String // "VAT 12%", "Service charge 5%"
  rate         Float // 0.12
  isInclusive  Boolean  @default(false)
  isDefault    Boolean  @default(false)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  @@index([ownerAdminId])
  @@map("tax_rates")
}

// API keys for external integrations.
model ApiKey {
  id           String    @id @default(cuid())
  ownerAdminId String
  label        String
  keyHash      String    @unique
  scopes       String    @default("read")
  lastUsedAt   DateTime?
  expiresAt    DateTime?
  isRevoked    Boolean   @default(false)
  createdAt    DateTime  @default(now())

  @@index([ownerAdminId])
  @@map("api_keys")
}

// Printer registry.
model PrinterDevice {
  id           String      @id @default(cuid())
  ownerAdminId String
  name         String // "Kitchen 1", "Bar", "Receipt"
  type         PrinterType @default(RECEIPT)
  connection   String      @default("network") // network | bluetooth | usb
  ipAddress    String?
  port         Int?        @default(9100)
  bluetoothMac String?
  paperWidth   String      @default("80mm") // 80mm | 58mm
  isDefault    Boolean     @default(false)
  isActive     Boolean     @default(true)
  notes        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([ownerAdminId])
  @@map("printer_devices")
}

enum PrinterType {
  RECEIPT
  KITCHEN
  BAR
  LABEL
  REPORT
}

// ═══════════════════════════════════════════════════════════════════════════
// POS EXTENSIONS — Gift cards, employee timeclock
// ═══════════════════════════════════════════════════════════════════════════

model GiftCard {
  id            String               @id @default(cuid())
  ownerAdminId  String
  code          String               @unique
  initialValue  Float
  balance       Float
  currency      String               @default("UZS")
  issuedToName  String?
  issuedToPhone String?
  issuedAt      DateTime             @default(now())
  expiresAt     DateTime?
  isActive      Boolean              @default(true)
  redemptions   GiftCardRedemption[]
  notes         String?

  @@index([ownerAdminId])
  @@map("gift_cards")
}

model GiftCardRedemption {
  id          String   @id @default(cuid())
  giftCardId  String
  giftCard    GiftCard @relation(fields: [giftCardId], references: [id], onDelete: Cascade)
  orderId     String?
  amount      Float
  performedBy String?
  createdAt   DateTime @default(now())

  @@index([giftCardId, createdAt])
  @@map("gift_card_redemptions")
}

model TimeclockEntry {
  id           String    @id @default(cuid())
  employeeId   String // Admin id
  ownerAdminId String
  clockedInAt  DateTime
  clockedOutAt DateTime?
  breakMinutes Int       @default(0)
  notes        String?
  createdAt    DateTime  @default(now())

  @@index([employeeId, clockedInAt])
  @@index([ownerAdminId])
  @@map("timeclock_entries")
}

// Cash drawer movements — manual cash in/out (paid-in, paid-out, drop, change-fund).
// Linked to a cashier shift so the closing reconciliation can account for them.
model CashDrawerMovement {
  id          String             @id @default(cuid())
  shiftId     String
  shift       CashierShift       @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  type        CashDrawerMoveType
  amount      Float // signed: positive = in, negative = out
  reason      String?
  performedBy String? // Admin id
  createdAt   DateTime           @default(now())

  @@index([shiftId, createdAt])
  @@map("cash_drawer_movements")
}

enum CashDrawerMoveType {
  PAID_IN // cash added (e.g. tips, manual top-up)
  PAID_OUT // cash removed (e.g. petty expense, supplier paid in cash)
  DROP // cash sent to safe / deposit
  CHANGE_FUND // change brought in
  ADJUSTMENT // manual reconciliation
}

// ─── Tip Pool ─────────────────────────────────────────────────────────────
// Tip pooling and distribution. Inspired by Toast POS tip-pool / tip-share.
// At end of shift / day the manager opens a tip-pool for a date range and
// distributes the collected tips across selected employees by weight (e.g.
// servers 50%, kitchen 30%, support 20%).

model TipPool {
  id            String           @id @default(cuid())
  ownerAdminId  String
  fromDate      DateTime
  toDate        DateTime
  totalAmount   Float            @default(0)
  status        TipPoolStatus    @default(OPEN)
  createdBy     String? // Admin id
  notes         String?
  shares        TipPoolShare[]
  createdAt     DateTime         @default(now())
  closedAt      DateTime?

  @@index([ownerAdminId, fromDate])
  @@map("tip_pools")
}

enum TipPoolStatus {
  OPEN
  DISTRIBUTED
  CANCELED
}

model TipPoolShare {
  id          String   @id @default(cuid())
  poolId      String
  pool        TipPool  @relation(fields: [poolId], references: [id], onDelete: Cascade)
  employeeId  String // Admin id
  weight      Float    @default(1) // Relative weight; share = weight / sum(weights) * pool.totalAmount
  computedAmount Float @default(0)
  paidOut     Boolean  @default(false)
  paidOutAt   DateTime?
  createdAt   DateTime @default(now())

  @@index([poolId])
  @@index([employeeId])
  @@map("tip_pool_shares")
}

// ─── Shift Checklist ─────────────────────────────────────────────────────
// Digital opening/closing checklist required before / after each shift.
// Inspired by Lightspeed K-Series March 2026 release. The owner defines a
// list of templates; when a cashier opens / closes a shift, an instance is
// generated and they tick boxes off — only then can the shift transition.

model ShiftChecklistTemplate {
  id           String                @id @default(cuid())
  ownerAdminId String
  name         String // "Opening checklist", "Bar closing"
  phase        ShiftChecklistPhase   @default(OPENING)
  isActive     Boolean               @default(true)
  items        ShiftChecklistItem[]
  instances    ShiftChecklistInstance[]
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  @@index([ownerAdminId, phase])
  @@map("shift_checklist_templates")
}

enum ShiftChecklistPhase {
  OPENING
  CLOSING
  MIDSHIFT
}

model ShiftChecklistItem {
  id          String                  @id @default(cuid())
  templateId  String
  template    ShiftChecklistTemplate  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  label       String // "Counted opening float", "Cleaned grill"
  required    Boolean                 @default(true)
  sortOrder   Int                     @default(0)
  responses   ShiftChecklistResponse[]
  createdAt   DateTime                @default(now())

  @@index([templateId, sortOrder])
  @@map("shift_checklist_items")
}

model ShiftChecklistInstance {
  id           String                   @id @default(cuid())
  templateId   String
  template     ShiftChecklistTemplate   @relation(fields: [templateId], references: [id], onDelete: Cascade)
  shiftId      String? // CashierShift id (optional — checklist can be daily too)
  performedBy  String // Admin id
  startedAt    DateTime                 @default(now())
  completedAt  DateTime?
  responses    ShiftChecklistResponse[]
  createdAt    DateTime                 @default(now())

  @@index([shiftId])
  @@index([performedBy, startedAt])
  @@map("shift_checklist_instances")
}

model ShiftChecklistResponse {
  id          String                  @id @default(cuid())
  instanceId  String
  instance    ShiftChecklistInstance  @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  itemId      String
  item        ShiftChecklistItem      @relation(fields: [itemId], references: [id], onDelete: Cascade)
  checked     Boolean                 @default(false)
  note        String?
  checkedAt   DateTime?
  createdAt   DateTime                @default(now())

  @@unique([instanceId, itemId])
  @@map("shift_checklist_responses")
}
